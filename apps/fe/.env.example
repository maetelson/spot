# ─────────────────────────────────────────────────────────────
# spot. environment variables — copy to `.env` and fill in
# `.env` is gitignored. Only VITE_* vars are exposed to the client.
# ─────────────────────────────────────────────────────────────

# Supabase (Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Kakao — JavaScript key (지도 SDK + 키워드 검색)
# Kakao Developers → 내 애플리케이션 → 앱 키 → JavaScript 키
# 플랫폼 > Web 사이트 도메인에 http://localhost:5173 (+배포 도메인) 등록 필요
VITE_KAKAO_JS_KEY=your-kakao-javascript-key

# Kakao — REST API key (SERVER-SIDE ONLY)
# ⚠️ VITE_ 접두어로 노출하지 말 것! 클라이언트 번들에 그대로 박힙니다.
# 등록 검색은 JS SDK services 라이브러리로 처리하므로 1.0에서는 불필요.
# 서버(Edge Function 등)에서 Local API를 쓸 때만 백엔드 환경변수로 보관.
# KAKAO_REST_KEY=your-kakao-rest-key
